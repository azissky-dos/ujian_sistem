{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "start": "apache2-foreground",
    "restartPolicyType": "ON_FAILURE"
  },
  "nixpacks": {
    "providers": ["php"],
    "pkgs": [
      "php82",
      "php82Packages.mysqli",
      "php82Extensions.mysqli"
    ]
  }
}